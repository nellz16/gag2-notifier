# Telegram
TELEGRAM_BOT_TOKEN=123456789:AAxxxx_from_BotFather
TELEGRAM_CHANNEL_ID=@your_public_channel_username
TELEGRAM_CHANNEL_URL=https://t.me/your_public_channel_username
# Optional but recommended: your numeric Telegram user ID, for /testchannel restriction
BOT_OWNER_ID=

# Polar upstream
POLAR_SUPABASE_URL=https://xcxciixqhmghitmyigbj.supabase.co
POLAR_SUPABASE_ANON=PASTE_POLAR_ANON_KEY_HERE

# Your own Supabase project for Telegram user watchlists + bot state
BOT_SUPABASE_URL=https://your-project.supabase.co
BOT_SUPABASE_SERVICE_ROLE=PASTE_YOUR_OWN_SUPABASE_SERVICE_ROLE_KEY_HERE

# Koyeb will provide PORT automatically, but 3000 is fine too
PORT=3000

# Update strategy
REST_FALLBACK_ENABLED=1
REST_FALLBACK_DELAY_SECONDS=30
# Optional: add extra retry if Polar is often late, e.g. 60 or 45,90. Leave empty for only +30s.
FALLBACK_EXTRA_RETRY_SECONDS=

# Initial behavior
SEND_INITIAL_TO_CHANNEL=0
PRIVATE_MATCH_HEADER=0
NOTIFY_DELAY_MS=80
BOT_BRAND=GAG2 Stock Bot

# Optional: manual items that appear in /watch even if not currently in stock
KNOWN_ITEMS=dragon fruit,mushroom,green bean,banana,grape,coconut,mango,sunflower,venus fly trap,pomegranate,poison apple,moon bloom,dragon's breath,thorn rose,glow mushroom,horned melon
